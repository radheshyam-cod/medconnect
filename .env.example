# ─── Database ───
DATABASE_URL="postgresql://postgres:password@localhost:5432/medconnect?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/medconnect?schema=public"

# ─── Clerk Auth ───
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# ─── Supabase (Storage) ───
NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_SERVICE_KEY="eyJ..."
SUPABASE_STORAGE_BUCKET="documents"

# ─── OpenAI ───
OPENAI_API_KEY="sk-..."

# ─── Google Document AI ───
GOOGLE_APPLICATION_CREDENTIALS='{}'
GOOGLE_DOC_AI_PROCESSOR_ID="projects/xxx/locations/us/processors/xxx"

# ─── Redis (BullMQ) ───
REDIS_URL="redis://localhost:6379"

# ─── Backend ───
API_PORT=3001
API_PREFIX="/api/v1"
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
JWT_SECRET="your-jwt-secret-change-in-production"

# ─── Feature Flags ───
NEXT_PUBLIC_ENABLE_OCR=true
NEXT_PUBLIC_ENABLE_AI=true
NEXT_PUBLIC_ENABLE_FAMILY=true
NEXT_PUBLIC_ENABLE_SHARING=true

# ─── Keploy (API Test Recording) ───
# Keploy is configured via keploy.yml in the project root.
# No environment variables required - CLI handles configuration.
# Commands:
#   pnpm keploy:record   - Record API traffic
#   pnpm keploy:test     - Replay recorded tests
