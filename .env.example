# ─── MedConnect India — Environment Variables ───
# Copy this file to frontend/.env.local and backend/.env and fill in your values.

# ─── Application ───
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Backend API ───
API_PORT=3001
API_PREFIX=/api/v1
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ─── Database (PostgreSQL via Prisma) ───
DATABASE_URL="postgresql://postgres:password@localhost:5432/medconnect?schema=public"

# ─── Clerk Authentication ───
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Redis (BullMQ Queue) ───
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Supabase (Storage) ───
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_SERVICE_KEY="eyJ..."
SUPABASE_STORAGE_BUCKET=documents

# ─── Google Generative AI (Gemini) ───
GEMINI_API_KEY="your-gemini-api-key"

# ─── Google Cloud (Document AI) ───
GCP_PROJECT_ID="your-gcp-project-id"
DOCUMENT_AI_LOCATION=us
DOCUMENT_AI_PROCESSOR_ID="projects/xxx/locations/us/processors/xxx"
GOOGLE_APPLICATION_CREDENTIALS='{"type":"service_account"}'

# ─── Gnani Voice AI (Optional - Voice Features) ───
GNANI_API_KEY=
GNANI_API_URL=

# ─── Mem0 AI (Optional - Memory Layer) ───
MEM0_API_KEY=

# ─── Keploy (API Test Recording) ───
# Keploy is configured via keploy.yml in the project root.
# No environment variables required - CLI handles configuration.
