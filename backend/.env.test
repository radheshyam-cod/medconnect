# ──────────────────────────────────────────────
# MedConnect India - Test Environment Config
# ──────────────────────────────────────────────
# Duplicate this file as .env.local for local development.

# ─── Database ───
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medconnect_test?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/medconnect_test?schema=public

# ─── Auth (Clerk) ───
CLERK_SECRET_KEY=sk_test_placeholder_for_ci
CLERK_WEBHOOK_SECRET=whsec_placeholder_for_ci

# ─── Storage (Supabase) ───
SUPABASE_URL=http://localhost:8000
SUPABASE_SERVICE_KEY=placeholder-service-key
SUPABASE_STORAGE_BUCKET=documents

# ─── AI (Mem0) - Context Memory Layer ───
MEM0_API_KEY=m0_key_test_placeholder
MEM0_PROJECT_ID=proj_test_placeholder
MEM0_ORG_ID=org_test_placeholder
MEM0_BASE_URL=
MEM0_TIMEOUT=10000
MEM0_RETRIES=3
MEM0_CACHE_TTL=300
MEM0_CACHE_MAX_SIZE=500
MEM0_BATCH_SIZE=10

# ─── AI (Gemini) ───
GEMINI_API_KEY=test-gemini-key-placeholder

# ─── Google Document AI ───
GCP_PROJECT_ID=test-project-id
DOCUMENT_AI_LOCATION=us
DOCUMENT_AI_PROCESSOR_ID=test-processor-id

# ─── Queue (Redis) ───
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── API Config ───
API_PORT=3001
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development
