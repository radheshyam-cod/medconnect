# ─── Test Environment - MedConnect India ───
# Placeholder credentials for local development and CI.
# Never use real credentials in this file.

# Database (uses .env.example values)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/medconnect_test?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/medconnect_test?schema=public"

# Clerk Auth (placeholder - tests mock Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_placeholder"
CLERK_SECRET_KEY="sk_test_placeholder"
CLERK_WEBHOOK_SECRET="whsec_placeholder"

# Supabase (placeholder - tests mock Supabase)
NEXT_PUBLIC_SUPABASE_URL="http://localhost:8000"
SUPABASE_SERVICE_KEY="eyJ_test_placeholder"
SUPABASE_STORAGE_BUCKET="documents"

# AI Services (placeholder - tests mock AI)
GEMINI_API_KEY="test-gemini-key-placeholder"
GOOGLE_APPLICATION_CREDENTIALS="{}"
GOOGLE_DOC_AI_PROCESSOR_ID="projects/test/locations/us/processors/test"

# Redis (use local Docker)
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"

# Backend
API_PORT="3001"
API_PREFIX="/api/v1"
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"

# Feature Flags (enable all for testing)
NEXT_PUBLIC_ENABLE_OCR="true"
NEXT_PUBLIC_ENABLE_AI="true"
NEXT_PUBLIC_ENABLE_FAMILY="true"
NEXT_PUBLIC_ENABLE_SHARING="true"
