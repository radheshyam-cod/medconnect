{
  "name": "@medconnect/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/src/main",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:migrate": "prisma migrate dev --schema=../database/prisma/schema.prisma",
    "db:migrate:prod": "prisma migrate deploy --schema=../database/prisma/schema.prisma",
    "db:seed": "ts-node ../database/prisma/seed.ts",
    "db:studio": "prisma studio --schema=../database/prisma/schema.prisma",
    "db:generate": "prisma generate --schema=../database/prisma/schema.prisma",
    "db:push": "prisma db push",
    "format": "prisma format",
    "keploy:init": "curl -fsSL https://keploy.io/ent/install.sh | bash",
    "keploy:record": "keploy record -c \"node dist/main\" -p .keploy --enable-obfuscation",
    "keploy:test": "keploy test -c \"node dist/main\" -p .keploy --build-delay 10 --enable-obfuscation",
    "keploy:replay": "keploy test -c \"node dist/main\" -p .keploy --build-delay 10 --enable-obfuscation",
    "keploy:update": "keploy test -c \"node dist/main\" -p .keploy --build-delay 10 --enable-obfuscation --update",
    "keploy:clean": "rm -rf .keploy/ keploy/ coverage/",
    "keploy:docker:record": "keploy record -c \"docker compose -f docker-compose.yml up api\" -p .keploy --container-name medconnect-api --enable-obfuscation",
    "keploy:docker:test": "keploy test -c \"docker compose -f docker-compose.yml up api\" -p .keploy --container-name medconnect-api --build-delay 10 --enable-obfuscation",
    "test:api": "keploy test -c \"node dist/main\" -p .keploy --build-delay 10 --enable-obfuscation",
    "test:regression": "keploy test -c \"node dist/main\" -p .keploy --build-delay 10 --enable-obfuscation",
    "test:coverage": "jest --coverage",
    "test:all": "pnpm test:coverage && pnpm test:regression"
  },
  "dependencies": {
    "@clerk/backend": "^3.11.4",
    "@google-cloud/documentai": "^9.6.2",
    "@google/generative-ai": "^0.24.1",
    "@medconnect/database": "workspace:*",
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.3.0",
    "@prisma/client": "6.1.0",
    "@supabase/supabase-js": "^2.110.4",
    "bullmq": "^5.34.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "dayjs": "^1.11.13",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "mem0ai": "^3.1.0",
    "multer": "1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.1",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.16.0",
    "jest": "^29.7.0",
    "prisma": "6.1.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.64.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
